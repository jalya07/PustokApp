@using pustokApp.Models
@model List<Slider>

@{
    ViewData["Title"] = "Sliders";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Sliders Management</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Slider")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Slider
            </a>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <strong>No sliders found.</strong> Start by adding your first slider.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Button Text</th>
                        <th>Image</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var slider in Model)
                    {
                        <tr>
                            <td>@slider.Id</td>
                            <td>@slider.Title</td>
                            <td>
                                @if (string.IsNullOrEmpty(slider.Description) || slider.Description.Length <= 50)
                                {
                                    @slider.Description
                                }
                                else
                                {
                                    @(slider.Description.Substring(0, 50) + "...")
                                }
                            </td>
                            <td>
                                <span class="badge bg-secondary">@slider.ButtonText</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(slider.ImageUrl))
                                {
                                    <img src="~/assets/image/bg-images/@slider.ImageUrl" alt="@slider.Title" style="max-width: 80px; max-height: 60px; object-fit: cover;" />
                                }
                                else
                                {
                                    <span class="text-muted">No Image</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "Slider", new { id = slider.Id })" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="@Url.Action("Delete", "Slider", new { id = slider.Id })" class="btn btn-sm btn-danger deleteSlider">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .table-responsive {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        border-radius: 0.25rem;
    }

    img {
        border-radius: 0.25rem;
    }
</style>
@section scripts {
    <script>
        // Delete Slider
        $(document).on('click', '.deleteSlider', function (e) {
            e.preventDefault();
            const deleteUrl = $(this).attr("href");
            
            Swal.fire({
                title: "Are you sure?",
                text: "Do you want to delete this slider?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Delete",
                cancelButtonText: "Cancel"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: deleteUrl,
                        type: "get",
                        success: function () {
                            Swal.fire(
                                "Deleted!",
                                "The slider has been deleted successfully.",
                                "success"
                            ).then(() => {
                                location.reload();
                            });
                        },
                        error: function () {
                            Swal.fire(
                                "Error!",
                                "An error occurred while deleting the slider.",
                                "error"
                            );
                        }
                    });
                }
            });
        });
    </script>
}
