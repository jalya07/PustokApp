@using pustokApp.Models
@model Slider

@{
    ViewData["Title"] = "Delete Slider";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1>Delete Slider</h1>
            <hr />

            <div class="alert alert-danger" role="alert">
                <strong>Warning!</strong> You are about to delete this slider. This action cannot be undone.
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@Model.Title</h5>
                    <p class="card-text">@Model.Description</p>

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div class="mb-3">
                            <img src="~/assets/image/bg-images/@Model.ImageUrl" alt="@Model.Title" style="max-width: 300px; max-height: 200px; border-radius: 0.25rem;" />
                        </div>
                    }

                    <dl class="row">
                        <dt class="col-sm-3">Button Text:</dt>
                        <dd class="col-sm-9">@Model.ButtonText</dd>

                        <dt class="col-sm-3">Button URL:</dt>
                        <dd class="col-sm-9">@Model.ButtonUrl</dd>
                    </dl>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <form asp-action="DeleteConfirmed" method="post" style="display: inline;">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
                <a href="@Url.Action("Index", "Slider")" class="btn btn-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
